// KimchiLang Standard Library - HTTP Client
// Wrapper for Node.js http/https modules with a simple, promise-based API

type HttpResponse = {status: number, statusText: string, headers: any, body: any, ok: boolean}
type HttpOptions = {method: string, headers: any, body: any, timeout: number}

extern "./_http_helpers.js" {
  async fn httpRequest(url: string, method: string, headers: any, body: any, timeout: number): HttpResponse
}

expose fn _describe() {
  return "HTTP client: get, post, put, patch, delete, request"
}

/**
 * @param {string} url
 * @param {any} options
 * @returns {HttpResponse}
 */
expose fn get(url, options) {
  return request(url, { ...options, method: "GET" })
}

/**
 * @param {string} url
 * @param {any} body
 * @param {any} options
 * @returns {HttpResponse}
 */
expose fn post(url, body, options) {
  return request(url, { ...options, method: "POST", body: body })
}

/**
 * @param {string} url
 * @param {any} body
 * @param {any} options
 * @returns {HttpResponse}
 */
expose fn put(url, body, options) {
  return request(url, { ...options, method: "PUT", body: body })
}

/**
 * @param {string} url
 * @param {any} body
 * @param {any} options
 * @returns {HttpResponse}
 */
expose fn patch(url, body, options) {
  return request(url, { ...options, method: "PATCH", body: body })
}

/**
 * @param {string} url
 * @param {any} options
 * @returns {HttpResponse}
 */
expose fn del(url, options) {
  return request(url, { ...options, method: "DELETE" })
}

/**
 * @param {string} url
 * @param {any} options
 * @returns {HttpResponse}
 */
expose fn request(url, options) {
  guard url != null else { throw "request() requires a url" }

  dec opts = options ?? {}
  dec method = opts.method ?? "GET"
  dec headers = opts.headers ?? {}
  dec body = opts.body
  dec timeout = opts.timeout ?? 30000

  // Auto-set content-type for JSON bodies
  dec finalHeaders = { ...headers, "Content-Type": "application/json" }.if(body != null and headers["Content-Type"] == null).else(headers)

  dec result = httpRequest(url, method, finalHeaders, body, timeout)

  return result
}

/**
 * @param {any} params
 * @returns {string}
 */
expose fn queryString(params) {
  return Object.entries(params).map((pair) => encodeURIComponent(pair[0]) + "=" + encodeURIComponent(pair[1])).join("&")
}

/**
 * @param {string} baseUrl
 * @param {any} params
 * @returns {string}
 */
expose fn buildUrl(baseUrl, params) {
  dec qs = queryString(params)
  return "${baseUrl}?${qs}".if(qs != "").else(baseUrl)
}

// Create a client with default options (base URL, headers, etc.)
expose fn createClient(baseOptions) {
  dec baseUrl = baseOptions.baseUrl ?? ""
  dec defaultHeaders = baseOptions.headers ?? {}
  dec defaultTimeout = baseOptions.timeout ?? 30000

  dec makeReq = (method, path, body, options) => {
    dec url = "${baseUrl}${path}"
    dec opts = options ?? {}
    dec mergedHeaders = { ...defaultHeaders, ...(opts.headers ?? {}) }
    return request(url, {
      ...opts,
      method: method,
      body: body,
      headers: mergedHeaders,
      timeout: opts.timeout ?? defaultTimeout
    })
  }

  return {
    get: (path, options) => makeReq("GET", path, null, options),
    post: (path, body, options) => makeReq("POST", path, body, options),
    put: (path, body, options) => makeReq("PUT", path, body, options),
    patch: (path, body, options) => makeReq("PATCH", path, body, options),
    del: (path, options) => makeReq("DELETE", path, null, options)
  }
}
