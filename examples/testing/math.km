// Math utility module
// Example module to demonstrate unit testing

expose fn add(a, b) {
  return a + b
}

expose fn subtract(a, b) {
  return a - b
}

expose fn multiply(a, b) {
  return a * b
}

expose fn divide(a, b) {
  if b == 0 {
    throw Error.new("Cannot divide by zero")
  }
  return a / b
}

expose fn factorial(n) {
  |n < 0| => throw Error.new("Factorial not defined for negative numbers")
  |n <= 1| => return 1
  |true| => return n * factorial(n - 1)
}

expose fn fibonacci(n) {
  |n <= 0| => return 0
  |n == 1| => return 1
  |true| => return fibonacci(n - 1) + fibonacci(n - 2)
}

expose fn isPrime(n) {
  guard n > 1 else { return false }
  mut i = 2
  while i * i <= n {
    guard n % i != 0 else { return false }
    i += 1
  }
  return true
}
